{
  "name": "worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply stock-agent-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply stock-agent-db --remote"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.45.0",
    "fast-xml-parser": "^5.5.0",
    "@anthropic-ai/sdk": "^0.52.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "drizzle-kit": "^0.31.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
